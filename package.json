{
  "name": "silent-dev",
  "version": "1.0.0",
  "description": "A local AI task scheduler that watches GitHub Issues and dispatches Claude Code to handle them automatically",
  "keywords": [
    "ai",
    "agent",
    "github",
    "automation",
    "claude",
    "task-scheduler"
  ],
  "author": "zhuaijun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xazaj/silent-dev.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "tui": "tsx src/tui.tsx",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.3.1",
    "fullscreen-ink": "^0.1.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "mustache": "^4.2.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "string-width": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
